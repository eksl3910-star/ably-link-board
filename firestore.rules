rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isMaintenance() {
      return get(/databases/$(database)/documents/settings/global).data.isMaintenance == true;
    }

    // 점검 플래그는 모두가 읽을 수 있어야 게이트가 동작함
    match /settings/{docId} {
      allow read: if docId == "global";
      // settings 변경은 서버(Admin SDK)만 허용하고 클라이언트 쓰기는 차단
      allow write: if false;
    }

    // 점검 중에는 모든 데이터 접근(읽기/쓰기) 차단
    match /users/{nickname} {
      allow read, write: if !isMaintenance();
    }

    match /links/{linkId} {
      allow read, write: if !isMaintenance();
    }
  }
}
